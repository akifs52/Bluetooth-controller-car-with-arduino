                   </property>
                   <property name="styleSheet">
                    <string notr="true">QFrame#topbar2 {
    background: rgb(26, 26, 26);
    border: 1px solid rgb(58, 58, 58);
    border-radius: 8px;
    margin: 2px;
}

/* Modern Battery Status Widget */
#batteryContainer {
    background: rgba(38, 38, 38, 0.8);
    border: 1px solid rgba(129, 236, 255, 0.3);
    border-radius: 6px;
    padding: 4px 8px;
    margin: 2px;
}

#batteryIcon {
    color: rgb(255, 255, 255);
    font-size: 12px;
    padding: 0 4px;
}

#batteryText {
    color: rgb(255, 255, 255);
    font-weight: bold;
    font-size: 10px;
    padding: 0 4px;
}

#batteryBar {
    min-width: 50px;
    height: 4px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    position: relative;
}

#batteryBar::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 75%;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
        stop:0 rgb(129, 236, 255), 
        stop:0.5 rgb(0, 212, 236), 
        stop:1 rgb(129, 236, 255));
    border-radius: 1px;
}

</string>

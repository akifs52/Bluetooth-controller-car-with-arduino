    /* Scrollbar styling */
    QListWidget QScrollBar:vertical {
        background: rgb(38, 38, 38);
        width: 12px;
        border-radius: 6px;
        margin: 0;
    }
    
    QListWidget QScrollBar::handle:vertical {
        background: rgb(58, 58, 58);
        border-radius: 6px;
        min-height: 20px;
    }
    
    QListWidget QScrollBar::handle:vertical:hover {
        background: rgb(78, 78, 78);
    }
    

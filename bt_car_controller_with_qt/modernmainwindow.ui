  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #0e0e0e;
    color: #ffffff;
}

/* Header Bar */
#headerWidget {
    background-color: #0e0e0e;
    border-bottom: 1px solid #262626;
    padding: 0px;
}

#titleLabel {
    color: #81ecff;
    font-size: 24px;
    font-weight: bold;
    font-family: 'Space Grotesk';
    letter-spacing: 2px;
    text-transform: uppercase;
}

#connectButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #81ecff, stop:1 #00d4ec);
    color: #003840;
    border: none;
    border-radius: 20px;
    padding: 8px 24px;
    font-weight: bold;
    font-size: 12px;
    font-family: 'Space Grotesk';
    letter-spacing: 1px;
    text-transform: uppercase;
}

#connectButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #a1ffff, stop:1 #20f4ff);
}

#connectButton:pressed {
    transform: scale(0.95);
}

/* Side Navigation */
#sideNav {
    background-color: #1a1a1a;
    border-right: 1px solid #262626;
    padding: 0px;
}

#systemTitle {
    color: #81ecff;
    font-size: 20px;
    font-weight: bold;
    font-family: 'Space Grotesk';
}

#systemVersion {
    color: #adaaaa;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.navButton {
    background-color: transparent;
    border: none;
    padding: 12px 24px;
    text-align: left;
    color: #adaaaa;
    font-size: 14px;
    font-weight: 500;
    border-radius: 0px;
}

.navButton:hover {
    background-color: #262626;
    color: #81ecff;
}

.navButton.active {
    background-color: rgba(129, 236, 255, 0.1);
    color: #81ecff;
    border-left: 4px solid #81ecff;
}

#emergencyStopButton {
    background-color: #9f0519;
    color: #ffa8a3;
    border: none;
    border-radius: 12px;
    padding: 16px;
    font-weight: bold;
    font-family: 'Space Grotesk';
    text-transform: uppercase;
    letter-spacing: 1px;
}

#emergencyStopButton:hover {
    background-color: #bf0620;
}

/* Main Content Area */
#mainContent {
    background-color: #0e0e0e;
    padding: 24px;
}

/* Joystick Container */
#joystickContainer {
    background-color: #262626;
    border-radius: 20px;
    padding: 16px;
}

#joystickWidget {
    background: qradialgradient(cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0 #1a1a1a, stop:1 #000000);
    border-radius: 160px;
    border: 2px solid #333333;
}

/* D-Pad Controls */
#dpadContainer {
    background-color: #1a1a1a;
    border-radius: 24px;
    padding: 16px;
    border: 1px solid rgba(118, 117, 117, 0.1);
}

.dpadButton {
    background-color: #262626;
    border: none;
    border-radius: 12px;
    width: 64px;
    height: 64px;
    color: #ffffff;
    font-size: 24px;
}

.dpadButton:hover {
    background-color: #81ecff;
    color: #003840;
}

.dpadButton:pressed {
    transform: scale(0.95);
}

#centerButton {
    background-color: #000000;
    border: none;
}

/* Gauge Containers */
.gaugeContainer {
    background-color: #1a1a1a;
    border-radius: 32px;
    padding: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.gaugeTitle {
    color: #adaaaa;
    font-size: 14px;
    font-family: 'Space Grotesk';
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 32px;
}

.gaugeValue {
    color: #ffffff;
    font-size: 48px;
    font-weight: bold;
    font-family: 'Space Grotesk';
}

.gaugeUnit {
    color: #adaaaa;
    font-size: 12px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.gaugeLimit {
    color: #ffffff;
    font-size: 20px;
    font-family: 'Space Grotesk';
}

.gaugeStatus {
    color: #81ecff;
    font-size: 12px;
    font-weight: bold;
}

/* Status Cards */
.statusCard {
    background-color: #131313;
    border-radius: 16px;
    padding: 16px;
    border: 1px solid rgba(118, 117, 117, 0.1);
}

.statusLabel {
    color: #767575;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: bold;
}

.statusValue {
    color: #ffffff;
    font-size: 14px;
    font-weight: bold;
    font-family: 'Space Grotesk';
}

.progressBar {
    background-color: #262626;
    border-radius: 4px;
    height: 4px;
}

.progressFill {
    background-color: #81ecff;
    border-radius: 4px;
}

/* Mobile Bottom Nav */
#bottomNav {
    background-color: rgba(14, 14, 14, 0.9);
    border-top: 1px solid #262626;
    border-radius: 16px 16px 0px 0px;
}

.bottomNavButton {
    background-color: transparent;
    border: none;
    padding: 8px 16px;
    color: #adaaaa;
    border-radius: 12px;
}

.bottomNavButton.active {
    background-color: rgba(129, 236, 255, 0.1);
    color: #81ecff;
}

.bottomNavButton:hover {
    color: #ffffff;
}</string>
